{
  "manifest_version": 3,
  "name": "RustChain Balance",
  "version": "1.0.0",
  "description": "View your RTC balance in real-time",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "alarms"],
  "host_permissions": ["https://50.28.86.131/*"]
}
